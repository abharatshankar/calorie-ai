APP_NAME="Calorie AI Backend"
APP_ENV=development
APP_VERSION=0.1.0
APP_DESCRIPTION="AI Nutrition Backend"
DEBUG=true
# Comma-separated list of allowed browser origins (empty = CORS disabled)
CORS_ORIGINS=

POSTGRES_DB=calorie_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/calorie_ai

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET_KEY=replace-with-another-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
